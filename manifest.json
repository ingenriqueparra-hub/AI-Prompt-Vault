{
  "manifest_version": 3,
  "name": "AI Prompt Vault",
  "version": "2.0",
  "description": "Almacena prompts por modelo de IA, con imagenes referenciales, copiado rapido y memoria persistente.",
  "permissions": ["activeTab", "clipboardRead", "clipboardWrite", "storage", "tabs", "sidePanel"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://www.perplexity.ai/*",
    "https://www.midjourney.com/*",
    "https://ideogram.ai/*",
    "https://stablediffusionweb.com/*"
  ],
  "action": {
    "default_icon": {
      "48": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["chatgpt_content.js"]
    }
  ]
}
